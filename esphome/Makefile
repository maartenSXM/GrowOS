# Use this Makefile with target argument <cmd><cpuNum>
# <cmd> can be any valid esphome command such as:
#   'clean', 'compile', 'config', 'upload', or 'logs.
# Convenience <cmd> 'update' does a 'compile' and then an 'upload'.
#   (See 'esphome -h for more help on valid <cmds>)
# <cpuNum> is 0 or 1 or blank to issue <cmd> for both cpus
#
# e.g. make compile0 or make update
#
ifeq ($(VIRTUAL_ENV),)
  $(error source esphome.git/venv/bin/activate)
endif

ifeq ($(USER),maarten)
  LOCATION = sxm
  SERIAL = 100
else
  LOCATION = pec
  SERIAL = 101
endif

ESPHOME = esphome -s LOCATION $(LOCATION) -s SERIAL $(SERIAL)
YAML_PREFIX  = cpu

update0:   compile0 upload0
update1:   compile1 upload1
logs:
	@echo "Choose logs0 or logs1"

%: %0 %1
	@/bin/true

define setupLocation
	@rm -f location.yaml
	@echo "# DO NOT EDIT THIS FILE!!" > location.yaml
	@cat location.$(LOCATION) >> location.yaml
	@chmod 444 location.yaml
endef

%0:
	@$(setupLocation)
	$(ESPHOME) -s CPU 0 `basename $@ 0` $(YAML_PREFIX)0.yaml

%1:
	@$(setupLocation)
	$(ESPHOME) -s CPU 1 `basename $@ 1` $(YAML_PREFIX)1.yaml

Makefile: ;

.PHONY: update0 update1
