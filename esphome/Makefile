# Use this Makefile with target argument <cmd><cpuNum>
# <cmd> can be any valid esphome command such as:
#   'clean', 'compile', 'config', 'upload', or 'logs.
# Convenience <cmd> 'update' does a 'compile' and then an 'upload'.
#   (See 'esphome -h for more help on valid <cmds>)
# <cpuNum> is 0 or 1 or blank to issue <cmd> for both cpus
#
# e.g. make compile0 or make update
#
ifeq ($(VIRTUAL_ENV),)
  $(error source esphome.git/venv/bin/activate)
endif

ifeq ($(USER),maarten)
  LOCATION = sxm
  SERIALNO = 100
else
  LOCATION = pec
  SERIALNO = 101
endif

ESPHOME   = esphome
GB_PREFIX = cpu
GB_LOC    = location.yaml

all:	 compile0  
update0: compile0 upload0
update1: compile1 upload1
logs:
	@echo "Choose logs0 or logs1"

%: %0 %1
	@/bin/true

define setupLocation
	@rm -f $(GB_LOC)
	@printf "#						\
	\n# *** DO NOT EDIT THIS FILE! ***			\
	\n#							\
	\n# These substitutions from ./Makefile:		\
	\n#							\
	\n  CPU:      \"$(1)\"					\
	\n  SERIALNO:   \"$(SERIALNO)\"				\
	\n  LOCATION: \"$(LOCATION)\"				\
	\n#							\
	\n# These substitutions from ./location.$(LOCATION):	\
	\n#							\
	\n" > $(GB_LOC)
	@cat ./location.$(LOCATION) >> $(GB_LOC)
endef

%0:
	@$(call setupLocation,0)
	$(ESPHOME) `basename $@ 0` $(GB_PREFIX)0.yaml

%1:
	@$(call setupLocation,1)
	$(ESPHOME) `basename $@ 1` $(GB_PREFIX)1.yaml

location.yaml: always-create
	@$(call setupLocation,0)

Makefile: ;

clean: clean0 clean1
	@rm -f $(GB_LOC)

.PHONY: update0 update1 always-create clean all logs *0 *1
